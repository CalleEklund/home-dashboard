{
  "name": "home-dashboard",
  "private": true,
  "scripts": {
    "client": "pnpm --filter @home-dashboard/client dev",
    "build": "pnpm --filter @home-dashboard/api-schema build && pnpm --filter @home-dashboard/client build",
    "generate": "pnpm --filter @home-dashboard/api-schema generate",
    "lint": "pnpm --filter @home-dashboard/client lint",
    "server": "pnpm --filter @home-dashboard/server dev",
    "docker:up": "pnpm --filter @home-dashboard/local-infra run up",
    "docker:down": "pnpm --filter @home-dashboard/local-infra run down",
    "docker:logs": "pnpm --filter @home-dashboard/local-infra run logs",
    "docker:build": "pnpm --filter @home-dashboard/local-infra run build",
    "chrome": "pnpm --filter @home-dashboard/local-infra run chrome"
  }
}
